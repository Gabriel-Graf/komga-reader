<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Relaunch the app after a self-update: a full-screen-intent notification reopens it (background
         activity launch is restricted, so a direct startActivity is best-effort only). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--
      Plugin-Deinstallation: das Trash-Icon im Plugins-Tab startet die System-UninstallerActivity
      via ACTION_DELETE. Ohne diese Permission lehnt sie ab ("Uid does not have
      REQUEST_DELETE_PACKAGES") und das Paket bleibt installiert. Normale (install-time) Permission,
      kein Runtime-Prompt — symmetrisch zu REQUEST_INSTALL_PACKAGES für den Install-Pfad.
    -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <!--
      Plugin-Entdeckung (Phase 4): ab Android 11 (API 30) filtert das OS die Sicht auf andere
      installierte Pakete. Der Plugin-Loader (PluginHost.discoverPlugins via getInstalledPackages)
      braucht daher Paket-Sichtbarkeit. QUERY_ALL_PACKAGES hält den Plugin-Vertrag MINIMAL — ein
      Plugin deklariert nur Manifest-Metadata, KEINE Discovery-Komponente (Mihon-Modell). Alternative
      wäre ein intent-basiertes <queries> (Play-policy-konform), das aber jedem Plugin einen
      exportierten Discovery-Stub aufzwingt = mehr ABI-Last. Die App wird sideloaded (AGPL/MuPDF,
      nicht über Play), daher ist die Play-sensitive Permission hier vertretbar.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".KomgaReaderApp"
        android:allowBackup="false"
        android:label="Komga Reader"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        tools:replace="android:allowBackup,android:label,android:icon,android:roundIcon"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              Open-with handler: register MainActivity for VIEW intents on book file types so the
              system "Open with" sheet (and file managers) can hand us a content:// URI. The intent
              is captured in captureViewIntent and routed by the ephemeral-open driver in setContent.
              octet-stream is included because many file managers report CBZ/CBR with a generic mime;
              detectBookFormat falls back to the file-name extension in that case.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/epub+zip" />
                <data android:scheme="content" android:mimeType="application/pdf" />
                <data android:scheme="content" android:mimeType="application/zip" />
                <data android:scheme="content" android:mimeType="application/vnd.comicbook+zip" />
                <data android:scheme="content" android:mimeType="application/x-cbz" />
                <data android:scheme="content" android:mimeType="application/x-cbr" />
                <data android:scheme="content" android:mimeType="application/vnd.comicbook-rar" />
                <data android:scheme="content" android:mimeType="application/vnd.rar" />
                <data android:scheme="content" android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".ui.plugins.repo.PluginInstallReceiver"
            android:exported="false" />
        <!-- Relaunches the app automatically after a self-update install. -->
        <receiver
            android:name=".update.UpdateRelaunchReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
