<?xml version="1.0" encoding="utf-8"?>
<!--
    Self-hosted media servers (Komga/Kavita/Suwayomi/OPDS) commonly run over plain HTTP on a LAN,
    e.g. http://192.168.1.10:4567. Android's network-security-config cannot express IP or CIDR
    ranges — only exact hostnames or a blanket setting — so there is no way to allow "all private
    LAN addresses" selectively. Cleartext is therefore permitted app-wide: the user only ever
    connects to servers they configure themselves, and HTTPS is still used whenever the server
    provides it (system trust anchors stay in effect for certificate validation).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
