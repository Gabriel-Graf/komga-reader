.superpowers/
.gradle/
build/
local.properties
.idea/
*.iml
.DS_Store

# Git worktrees (isolierte Arbeitsbereiche)
.claude/worktrees/

# Lokaler Tooling-Cache (z. B. unit-test-reviewer-Marker) — maschinenspezifisch
.claude/.cache/

# Lokaler Real-Page-Korpus für PanelDetector-Harness (urheberrechtlich, nie committen)
guided-view/realpages/

# Icon-Generator (Node) — Deps nicht tracken
tools/icons/node_modules/

# Plugin-Projekte: eigene Git-Repos unter plugin/, NICHT Teil des Host-Repos
# Root-anchored, sonst matcht es auch den Package-Pfad com/komgareader/plugin/ in plugin-host/plugin-api.
/plugin/

# Externe Plugin-Repos: jedes Plugin eigenes Git-Repo, nicht im Haupt-Repo (siehe plugins/README.md).
/plugins/*/
!/plugins/_template-data/
