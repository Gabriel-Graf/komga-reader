<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
      Plugin-Entdeckung (Phase 4): ab Android 11 (API 30) filtert das OS die Sicht auf andere
      installierte Pakete. Der Plugin-Loader (PluginHost.discoverPlugins via getInstalledPackages)
      braucht daher Paket-Sichtbarkeit. QUERY_ALL_PACKAGES hält den Plugin-Vertrag MINIMAL — ein
      Plugin deklariert nur Manifest-Metadata, KEINE Discovery-Komponente (Mihon-Modell). Alternative
      wäre ein intent-basiertes <queries> (Play-policy-konform), das aber jedem Plugin einen
      exportierten Discovery-Stub aufzwingt = mehr ABI-Last. Die App wird sideloaded (AGPL/MuPDF,
      nicht über Play), daher ist die Play-sensitive Permission hier vertretbar.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".KomgaReaderApp"
        android:allowBackup="false"
        android:label="Komga Reader"
        tools:replace="android:allowBackup,android:label"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".ui.plugins.repo.PluginInstallReceiver"
            android:exported="false" />
    </application>
</manifest>
